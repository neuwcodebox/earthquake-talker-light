TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
KMA_API_KEY=

# Set to 1 to print messages without sending them to Telegram.
DRY_RUN=0

# Optional runtime settings.
OUTPUT_DIR=output
POLL_INTERVAL_SECONDS=1
MICRO_INTERVAL_SECONDS=10
PEWS_INTERVAL_SECONDS=1
OVERSEAS_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=15

# Optional PEWS replay mode: earthquake_id:start_time.
# start_time is KST, format: yyyyMMddHHmmss.
# Examples from the old implementation:
# - 2017000407:20171115142931
# - 2020005363:20200511194506
# - 2021000517:20210203121756
# - 2021007178:20211214171904
PEWS_SIMULATION=
